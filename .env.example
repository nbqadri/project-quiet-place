# ─────────────────────────────────────────────────────
#  YouTube Shorts Generator – Environment Variables
# ─────────────────────────────────────────────────────

# Required: Anthropic Claude API key
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required for image fetching: Pexels API key (free)
# Get yours at https://www.pexels.com/api/
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: YouTube Data API v3 OAuth2 client secrets file
# Download from https://console.cloud.google.com/ → Credentials
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# Optional: Logging verbosity (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# ─── Branding ────────────────────────────────────────────────────────────────
# Customize the intro card and call-to-action text
BRAND_TITLE=CALM
BRAND_SUBTITLE=REFLECTIONS
CTA_TEXT=Subscribe for daily reflections

# Your YouTube Channel ID (UC...) for multi-channel targeting
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxx

# Playlist ID – videos are automatically added after upload
YOUTUBE_PLAYLIST_ID=PLq5iQVvHtVDVLjsFmZ-rqXZqtm5qBq_oJ

# ─── Scheduling ──────────────────────────────────────────────────────────────
# Set to true to upload as private and auto-publish after a random delay
YOUTUBE_SCHEDULE=false
YOUTUBE_SCHEDULE_MIN_DAYS=1
YOUTUBE_SCHEDULE_MAX_DAYS=10

# ─── Related Videos ──────────────────────────────────────────────────────────
# Comma-separated list of your existing YouTube video IDs
# One is picked randomly and linked in each video description
# Example: YOUTUBE_RELATED_VIDEO_IDS=abc123xyz,def456uvw,ghi789rst
YOUTUBE_RELATED_VIDEO_IDS=
