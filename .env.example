# ─────────────────────────────────────────────────────
#  YouTube Shorts Generator – Environment Variables
# ─────────────────────────────────────────────────────

# Required: Anthropic Claude API key
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required for image fetching: Pexels API key (free)
# Get yours at https://www.pexels.com/api/
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: YouTube Data API v3 OAuth2 client secrets file
# Download from https://console.cloud.google.com/ → Credentials
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# Optional: Logging verbosity (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
